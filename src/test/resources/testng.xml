<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
    parallel="tests" + thread-count is what actually fans scenarios out concurrently. Cucumber's own @DataProvider(parallel = true) inside
    AbstractTestNGCucumberTests works IN COMBINATION with this suite's thread-count to determine real concurrency — both must agree with the
    ThreadLocal strategy in DriverFactory or WILL leak sessions.
-->
<suite name="Playwright-Cucumber-Suite" parallel="methods" thread-count="4" data-provider-thread-count="4" verbose="1">
    <test name="Cucumber-Regression-Test">
        <classes>
            <class name="com.framework.runners.TestNGRunner"/>
        </classes>
    </test>
</suite>
