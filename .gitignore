# --- Gradle Directories ---
.gradle/
build/

# --- IntelliJ IDEA Settings ---
.idea/
out/
*.iml
*.iws
*.ipr
local.properties

# --- Test Framework Outputs & Reports ---
# Cucumber, TestNG, ExtentReports or Allure execution reports should not be pushed
test-output/

# --- Playwright Execution Artifacts ---
# Prevents video recordings, traces, or screenshots from clogging git
test-results/
target/
playwright-report/
blob-report/

# --- Apps ---
# Prevents app files from upload.
*.apk
*.ipa

# Playwright execution binaries and localized driver installations
.local-browsers/

# --- System & Log Files ---
*.log
.DS_Store
Thumbs.db

# --- Optional Data Safety Rule ---
# Uncomment the line below if credentials or sensitive environments in config files
# src/test/resources/config/*.properties

